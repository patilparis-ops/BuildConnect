# ==================== Backend (backend/.env) ====================

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/postgres?schema=public"

# Session
SESSION_SECRET="your-random-secret-string-min-32-chars"

# Server
PORT=3001
FRONTEND_URL="http://localhost:5173"
NODE_ENV="development"

# Email (Resend - https://resend.com)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@buildconnect.in"

# PostgreSQL SSL Mode (for Supabase)
PGSSLMODE="prefer"

# ==================== Frontend (.env / Vite) ====================

# Backend API URL (empty means same origin in production)
VITE_API_URL="http://localhost:3001"
