# ============================
# BuildConnect Backend Config
# ============================

# Supabase PostgreSQL connection string (Session Pooler — IPv4 compatible)
# Get this from: Supabase Dashboard -> Project Settings -> Database -> Connection string (Session pooler)
# Make sure to replace [YOUR-PASSWORD] and [YOUR-PROJECT-REF]
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Session secret (generate a random string with: openssl rand -hex 32)
SESSION_SECRET="change-this-to-a-random-secret-in-production"

# Server
PORT=3001
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL="http://localhost:5173"
